{
    "name": "github-widget",
    "version": "1.0.0",
    "description": "A beautiful always-on-top GitHub contributions desktop widget",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder --win",
        "shortcut": "node create-shortcut.js"
    },
    "author": "Akshith Nallaginnela",
    "license": "MIT",
    "devDependencies": {
        "electron": "^33.0.0",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "appId": "com.akshith.github-widget",
        "productName": "GitHub Widget",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "widget.html",
            "widget-app.js",
            "index.html",
            "styles.css",
            "app.js",
            "icon.png",
            "set-bottom.ps1"
        ],
        "win": {
            "icon": "icon.png",
            "signAndEditExecutable": false,
            "target": "nsis"
        },
        "appx": {
            "identityName": "AKSHITH.GitHubWidget",
            "publisher": "CN=745B52D1-5598-4503-89F4-99D00C18BA0B",
            "publisherDisplayName": "Akshith Nallaginnela",
            "applicationId": "GitHubWidget",
            "displayName": "GitHub Widget"
        }
    }
}