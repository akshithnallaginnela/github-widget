{
    "name": "contribtracker",
    "version": "1.1.0",
    "description": "A premium desktop widget to track your contributions in real-time.",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder --win appx",
        "shortcut": "node create-shortcut.js"
    },
    "author": "Akshith Nallaginnela",
    "license": "MIT",
    "devDependencies": {
        "electron": "^33.0.0",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "appId": "com.akshith.contribtracker",
        "productName": "ContribTracker",
        "directories": {
            "output": "build_out"
        },
        "files": [
            "main.js",
            "preload.js",
            "widget.html",
            "widget-app.js",
            "index.html",
            "styles.css",
            "app.js",
            "icon.png",
            "set-bottom.ps1"
        ],
        "win": {
            "icon": "icon.png",
            "target": "appx",
            "signAndEditExecutable": false,
            "forceCodeSigning": false
        },
        "appx": {
            "identityName": "AKSHITH.ContribTracker",
            "publisher": "CN=745B52D1-5598-4503-89F4-99D00C18BA0B",
            "publisherDisplayName": "Akshith Nallaginnela",
            "applicationId": "ContribTracker",
            "displayName": "ContribTracker"
        }
    }
}
