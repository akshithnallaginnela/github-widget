{
    "name": "github-widget",
    "version": "1.0.0",
    "description": "A beautiful always-on-top GitHub contributions desktop widget",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder --win --dir",
        "shortcut": "node create-shortcut.js"
    },
    "author": "Akshith Nallaginnela",
    "license": "MIT",
    "devDependencies": {
        "electron": "^33.0.0",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "appId": "com.akshith.github-widget",
        "productName": "GitHub Widget",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "widget.html",
            "widget-app.js",
            "index.html",
            "styles.css",
            "app.js",
            "icon.png",
            "set-bottom.ps1"
        ],
        "win": {
            "icon": "icon.png",
            "signAndEditExecutable": false,
            "target": [
                {
                    "target": "msix",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "msix": {
            "publisher": "CN=Your Publisher Name",
            "identityName": "com.akshith.github-widget",
            "displayName": "GitHub Widget",
            "languages": [
                "en-US"
            ]
        }
    }
}